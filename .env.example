# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/talentcheck

# ─── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-min-32-chars-change-this
ALGORITHM=HS256

# ─── Supabase (optional — for storage) ────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# ─── Email (SendGrid) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=noreply@talentcheck.et

# ─── SMS (Africa's Talking) ───────────────────────────────────────────────────
AFRICAS_TALKING_API_KEY=your-key
AFRICAS_TALKING_USERNAME=sandbox

# ─── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
DEBUG=true

# ─── Frontend (.env.local in web/) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
