    {"id": "dev_003", "type": "mcq", "category": "python", "text": "What does the following list comprehension produce: [x**2 for x in range(4)]?", "options": [{"key": "A", "text": "[1, 4, 9, 16]"}, {"key": "B", "text": "[0, 1, 4, 9]"}, {"key": "C", "text": "[0, 2, 4, 6]"}, {"key": "D", "text": "[1, 2, 3, 4]"}], "correct_answer": "B"},
